<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # No reescribir assets o archivos reales
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L,QSA]
</IfModule>

# ── Bloquear ejecución PHP en /uploads (via uploads/.htaccess) ────────────────
# La carpeta public/uploads/ tiene su propio .htaccess con Require all denied

# ── Headers de seguridad HTTP ─────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# ── Forzar HTTPS en producción (descomentarlo en prod) ────
# <IfModule mod_rewrite.c>
#     RewriteCond %{HTTPS} off
#     RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
# </IfModule>

# ── Tiempo de expiración de assets ───────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css             "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png            "access plus 1 month"
    ExpiresByType image/jpeg           "access plus 1 month"
    ExpiresByType image/svg+xml        "access plus 1 month"
    ExpiresByType image/x-icon         "access plus 1 year"
</IfModule>
