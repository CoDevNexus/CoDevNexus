Options -Indexes

# ── Redirige todo al front-controller en public/ ─────────────────────────────
# Necesario cuando el DocumentRoot del servidor apunta a la raíz del proyecto
# en lugar de apuntar directamente a public/.

RewriteEngine On

# Si el archivo/directorio existe realmente en la raíz, sérvelo directo
# (ej: .well-known/acme-challenge para certificados SSL)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Todo lo demás → public/
RewriteRule ^(.*)$ public/$1 [L]
