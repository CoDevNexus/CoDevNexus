# ── Redirige todo al front-controller en public/ ─────────────────────────────
# Necesario cuando el DocumentRoot apunta a la raíz del proyecto.

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Sirve archivos/directorios reales de la raíz directamente
    # (ej: .well-known/acme-challenge para SSL)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Todo lo demás → public/
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>
