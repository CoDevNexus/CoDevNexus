# ── Redirige todo al front-controller en public/ ─────────────────────────────
# Necesario cuando el DocumentRoot apunta a la raíz del proyecto.

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 0. Raíz del sitio → siempre al front-controller
    RewriteRule ^$ public/index.php [L,QSA]

    # 1. Sirve archivos estáticos reales que existan en public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L,QSA]

    # 2. Todo lo demás (rutas PHP) → public/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>
